# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

# Unix-style newlines with a newline ending every file
[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# Rust files: 4 spaces, max 90 chars (matches .rustfmt.toml)
[*.rs]
indent_size = 4
tab_width = 4
max_line_length = 90

# TOML files: 2 spaces (Cargo.toml, config files)
[*.toml]
indent_size = 2
tab_width = 2

# Markdown files
[*.md]
indent_size = 2
tab_width = 2
trim_trailing_whitespace = false

# YAML files
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# JSON files
[*.json]
indent_style = space
indent_size = 2
tab_width = 2

# Shell scripts
[*.sh]
indent_style = space
indent_size = 4

# Makefiles
[Makefile]
indent_style = tab
indent_size = 4

# Dockerfile
[Dockerfile]
indent_style = space
indent_size = 4
